			await _context.SaveChangesAsync();
			return userdeatail;
		}

		public async Task <bool>DeleteUserdeatailAsync(int id)
		{
			var userdetail = await _context.Userdeatails.FindAsync(id);
			if (userdetail == null)
			{  return false; }
				
			_context.Users.Remove(userdetail);
			await _context.SaveChangesAsync();
			return true;
		}

		public Task<IEnumerable<Userdeatail>> GetAlUserdeatailAsync()
		{
			throw new NotImplementedException();
		}
	}

}